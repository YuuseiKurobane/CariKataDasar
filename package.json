{
  "name": "cari-kata-dasar",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone Indonesian candidate-generation and parser-debugging harness for Yomitan.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build:headwords": "node scripts/build-headwords.mjs",
    "check:upstream": "node scripts/check-upstream.mjs",
    "debug:traces": "node scripts/write-debug-traces.mjs",
    "prepare:frequencies": "py scripts/prepare-debug-frequencies.py && node scripts/prepare-review-cases.mjs",
    "pretest": "node scripts/materialize-testcases.mjs",
    "test": "node --test"
  },
